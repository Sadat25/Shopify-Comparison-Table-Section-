
{%- style -%}
    .section-{{ section.id }} {
      padding-top: {{ section.settings.padding_top_mobile }}px;
      padding-bottom: {{ section.settings.padding_bottom_mobile }}px;
      background-color: {{ section.settings.background_color }};
      color: {{ section.settings.text_color }};
      overflow: hidden;
    }

    @media screen and (min-width: 750px) {
      .section-{{ section.id }} {
        padding-top: {{ section.settings.padding_top }}px;
        padding-bottom: {{ section.settings.padding_bottom }}px;
      }
    }

    .comparison-container-{{ section.id }} {
      max-width: 1420px;
      margin: 0 auto;
      padding: 0 10px;
      display: flex;
      flex-direction: column;
      gap: 50px;
    }

    @media screen and (min-width: 990px) {
      .comparison-container-{{ section.id }} {
        flex-direction: row;
        align-items: center;
      }
      .comparison-content-{{ section.id }} {
        flex: 1;
        /* padding-right: 80px; */
      }
      .comparison-table-wrapper-{{ section.id }} {
        flex: 1.5;
      }
    }

    .comparison-content-{{ section.id }} h2 {
      margin-top: 0;
      margin-bottom: 24px;
      font-size: clamp(2.5rem, 6vw, 48px);
      line-height: 1.1;
      font-weight: 500;
      color: #16332E;
      letter-spacing: -0.02em;
    }

    .comparison-content-{{ section.id }} .description {
      margin-bottom: 48px;
      line-height: 1.6;
      font-size: 1.1rem;
      color: #16332E;
      font-weight: 500;
    }


    .comparison-table-{{ section.id }} {
      width: 100%;
      border-collapse: separate;
      border-spacing: 0;
      border-radius: 12px;
      overflow: visible;
      position: relative;
    }

    .comparison-table-{{ section.id }} th,
    .comparison-table-{{ section.id }} td {
      padding: 24px 15px;
      text-align: center;
      vertical-align: middle;
    }

    /* Column 1 & 3 Styles */
    .comparison-table-{{ section.id }} th:nth-child(1),
    .comparison-table-{{ section.id }} th:nth-child(3) {
      background-color: #D6E8E3;
      color: #16332E;
      font-weight: 700;
      font-size: 18px;
      text-align:center;
    }

    .comparison-table-{{ section.id }} td:nth-child(1),
    .comparison-table-{{ section.id }} td:nth-child(3) {
      background-color: #FDE2C4;
      color: #16332E;
    }

    /* Feature Column Specifics */
    .comparison-table-{{ section.id }} td:first-child,
    .comparison-table-{{ section.id }} th:first-child {
      padding-left: 30px;
      width: 40%;
    }

    .feature-cell {
      display: flex;
      align-items: center;
      gap: 12px;
      font-weight: 700;
    }

    .feature-icon-badge {
      flex-shrink: 0;
      width: 24px;
      height: 24px;
      color: #7B1D21;
    }

    /* Highlighted Middle Column (Product) */
    .comparison-table-{{ section.id }} th:nth-child(2),
    .comparison-table-{{ section.id }} td:nth-child(2) {
      background-color: #FFFBF2;
      position: relative;
      z-index: 2;
    }

    .comparison-table-{{ section.id }} th:nth-child(2) {
      border-radius: 12px 12px 0 0;
      color: #16332E;
      font-weight: 700;
      font-size: 1.1rem;
      padding-top: 30px;
      padding-bottom: 30px;
      box-shadow: 0 -15px 40px rgba(0,0,0,0.06);
    }

    .comparison-table-{{ section.id }} td:nth-child(2) {
      box-shadow: 20px 0 40px -20px rgba(0,0,0,0.1), -20px 0 40px -20px rgba(0,0,0,0.1);
      font-weight: 600;
    }

    .comparison-table-{{ section.id }} tr:last-child td:nth-child(2) {
      border-radius: 0 0 12px 12px;
      box-shadow: 0 25px 50px rgba(0,0,0,0.12), 20px 0 40px -20px rgba(0,0,0,0.1), -20px 0 40px -20px rgba(0,0,0,0.1);
    }

    .comparison-table-{{ section.id }} tr:hover td:nth-child(2) {
      background-color: #ffffff;
      transition: background-color 0.2s ease;
    }

    /* Table Borders/Radius */
    .comparison-table-{{ section.id }} th:first-child { border-radius: 12px 0 0 0; }
    .comparison-table-{{ section.id }} th:last-child { border-radius: 0 12px 0 0; }
    .comparison-table-{{ section.id }} tr:last-child td:first-child { border-radius: 0 0 0 12px; }
    .comparison-table-{{ section.id }} tr:last-child td:last-child { border-radius: 0 0 12px 0; }

    .icon-box {
      display: flex;
      justify-content: center;
      align-items: center;
    }

    .icon-box svg {
      width: 24px;
      height: 24px;
    }

    .icon-box.check { color: #16332E; }
    .icon-box.cross { color: #7B1D21; }

    .animate-on-scroll {
      opacity: 0;
      transform: translateY(30px);
      transition: opacity 0.8s ease-out, transform 0.8s ease-out;
    }

    .animate-on-scroll.is-visible {
      opacity: 1;
      transform: translateY(0);
    }

    @media screen and (max-width: 989px) {
      .comparison-content-{{ section.id }} {
        text-align: center;
        padding-right: 0;
        display: flex;
        flex-direction: column;
        align-items: center;
      }
      .comparison-content-{{ section.id }} .description {
        margin-left: auto;
        margin-right: auto;
      }
    }

    @media screen and (max-width: 749px) {
      .comparison-table-wrapper-{{ section.id }} {
        overflow-x: auto;
        margin: 0 -10px;
        padding: 20px 10px;
      }
      .comparison-table-{{ section.id }} {
        min-width: 600px;
      }
      .comparison-table-{{ section.id }} th,
      .comparison-table-{{ section.id }} td {
        padding: 18px 10px;
      }
    }

    .comparison-table td {
    transition: all .25s ease;
  }

  .comparison-table tr:hover td {
    transform: translateY(-2px);
  }

  .comparison-table td:nth-child(2):hover {
    background: #FFFFFF;
    box-shadow: 0 10px 25px rgba(0,0,0,.08);
  }

  .icon-box.check {
    color: #16332E;
  }

  .icon-box.cross {
    color: #9B3A2E;
  }
{%- endstyle -%}

{%- capture icon_badge_check -%}
  <svg viewBox="0 0 24 24" fill="currentColor"><path d="M23 12l-2.44-2.79.34-3.69-3.61-.82-1.89-3.2L12 2.96 8.6 1.5 6.71 4.7l-3.61.81.34 3.7L1 12l2.44 2.79-.34 3.69 3.61.82 1.89 3.2L12 21.04l3.4 1.46 1.89-3.2 3.61-.82-.34-3.69L23 12zm-12.91 4.72l-3.8-3.81 1.48-1.48 2.32 2.33 5.85-5.87 1.48 1.48-7.33 7.35z"/></svg>
{%- endcapture -%}

{%- capture icon_check -%}
  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg>
{%- endcapture -%}

{%- capture icon_cross -%}
  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
{%- endcapture -%}

<section
  class="section-{{ section.id }} {% if section.settings.enable_animation %}animate-on-scroll{% endif %}"
  id="Comparison-{{ section.id }}"
>
  <div class="comparison-container-{{ section.id }}">
    <div class="comparison-content-{{ section.id }}">
      {% if section.settings.heading != blank %}
        <h2>{{ section.settings.heading }}</h2>
      {% endif %}
      {% if section.settings.description != blank %}
        <div class="description">{{ section.settings.description }}</div>
      {% endif %}
      {% if section.settings.button_label != blank %}
        <div class="m-hero__btn m:justify-center">
          <a
            href="{{ section.settings.button_link }}"
            class="m-button m-button--primary {{ section.settings.button_size }}"
          >
            {{ section.settings.button_label }}
          </a>
        </div>
      {% endif %}
    </div>

    <div class="comparison-table-wrapper-{{ section.id }}">
      <table class="comparison-table-{{ section.id }}">
        <thead>
          <tr>
            <th>Features</th>
            <th>{{ section.settings.product_column_name }}</th>
            <th>{{ section.settings.other_column_name }}</th>
          </tr>
        </thead>
        <tbody>
          {% for block in section.blocks %}
            <tr {{ block.shopify_attributes }}>
              <td>
                <div class="feature-cell">
                  <span class="feature-icon-badge">{{ icon_badge_check }}</span>
                  {{ block.settings.feature_name }}
                </div>
              </td>
              <td>
                <div class="icon-box check">
                  {% if block.settings.product_enabled %}
                    {{ icon_check }}
                  {% else %}
                    {{ icon_cross }}
                  {% endif %}
                </div>
              </td>
              <td>
                <div class="icon-box cross">
                  {% if block.settings.others_enabled %}
                    {{ icon_check }}
                  {% else %}
                    {{ icon_cross }}
                  {% endif %}
                </div>
              </td>
            </tr>
          {% endfor %}
        </tbody>
      </table>
    </div>
  </div>
</section>

{% if section.settings.enable_animation %}
  <script>
    (function () {
      const initAnimation = () => {
        const observer = new IntersectionObserver(
          (entries) => {
            entries.forEach((entry) => {
              if (entry.isIntersecting) {
                entry.target.classList.add('is-visible');
              }
            });
          },
          { threshold: 0.1 }
        );

        const section = document.querySelector('#Comparison-{{ section.id }}');
        if (section) observer.observe(section);
      };

      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', initAnimation);
      } else {
        initAnimation();
      }
    })();
  </script>
{% endif %}

{% schema %}
{
  "name": "Comparison Table",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "What Makes Us Better?"
    },
    {
      "type": "richtext",
      "id": "description",
      "label": "Description",
      "default": "<p>Experience unparalleled comfort with a uniquely designed pet bed that promises warmth, support, and a cozy retreat, ensuring your beloved pets feel cherished and secure while they rest.</p>"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "Shop Now"
    },
    {
      "type": "select",
      "id": "button_size",
      "label": "Button size",
      "default": "m-button--medium",
      "options": [
        { "value": "m-button--small", "label": "Small" },
        { "value": "m-button--medium", "label": "Medium" },
        { "value": "m-button--large", "label": "Large" }
      ]
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button Link"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background Color",
      "default": "#FFF8E7"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text Color",
      "default": "#16332E"
    },
    {
      "type": "text",
      "id": "product_column_name",
      "label": "Product Column Name",
      "default": "Paw Peace"
    },
    {
      "type": "text",
      "id": "other_column_name",
      "label": "Other Column Name",
      "default": "Others"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 150,
      "step": 5,
      "unit": "px",
      "label": "Padding Top",
      "default": 100
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 150,
      "step": 5,
      "unit": "px",
      "label": "Padding Bottom",
      "default": 100
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "label": "Mobile Padding Top",
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "label": "Mobile Padding Bottom",
      "default": 60
    },
    {
      "type": "checkbox",
      "id": "enable_animation",
      "label": "Enable Scroll Animation",
      "default": true
    }
  ],
  "blocks": [
    {
      "type": "row",
      "name": "Feature Row",
      "settings": [
        {
          "type": "text",
          "id": "feature_name",
          "label": "Feature Name",
          "default": "Feature Name"
        },
        {
          "type": "checkbox",
          "id": "product_enabled",
          "label": "Enable for Product",
          "default": true
        },
        {
          "type": "checkbox",
          "id": "others_enabled",
          "label": "Enable for Others",
          "default": false
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Comparison Table",
      "blocks": [
        {
          "type": "row",
          "settings": { "feature_name": "Ultimate Softness", "product_enabled": true, "others_enabled": false }
        },
        {
          "type": "row",
          "settings": { "feature_name": "Winter Warmth", "product_enabled": true, "others_enabled": false }
        },
        {
          "type": "row",
          "settings": { "feature_name": "Adjustable Sizes", "product_enabled": true, "others_enabled": false }
        },
        {
          "type": "row",
          "settings": { "feature_name": "Safety Design", "product_enabled": true, "others_enabled": false }
        },
        {
          "type": "row",
          "settings": { "feature_name": "Durable Quality", "product_enabled": true, "others_enabled": false }
        }
      ]
    }
  ]
}
{% endschema %}

